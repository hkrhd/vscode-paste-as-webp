{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--profile-temp",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: compile",
      "sourceMaps": true
    },
    {
      "name": "Run Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/test/suite/index.js",
        "--user-data-dir=${workspaceFolder}/.vscode-test/test-user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-test/test-extensions",
        "--profile-temp",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: pretest",
      "sourceMaps": true
    },
    {
      "name": "Run Local VS Code E2E",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run test:e2e:code"
    }
  ]
}
